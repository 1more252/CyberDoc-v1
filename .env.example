# ===========================================================================
# КиберДок (apn-vue) — пример конфига. Скопируйте в .env и поправьте
# под свою среду. Все переменные опциональны кроме JWT_SECRET в проде и
# ALLOWED_ORIGINS в проде.
# ===========================================================================

# ---------- Frontend (Vite) ------------------------------------------------
VITE_APP_TITLE=КиберДок

# true → in-memory мок (`src/mock/`), без сети. Удобно для standalone-демо.
# false → реальный бэк по адресу VITE_API_URL.
VITE_USE_MOCK_API=false

# Базовый URL бэка. В dev — `/api` (vite proxy на сервер из `server/`).
# В prod — полный URL (например https://api.example.com/api).
VITE_API_URL=/api

# ---------- Backend: http -------------------------------------------------
# Адрес/порт listen'а. 0.0.0.0 если бэк за reverse-proxy в контейнере.
PORT=3001
HOST=127.0.0.1

# true → бэк отдаёт SPA-статику из ./dist (single-container deploy).
# false → статика отдаётся отдельно (nginx/CDN); бэк только /api + /health.
SERVE_STATIC=false

# true → доверяем X-Forwarded-* (для rate-limit/audit получаем реальный IP).
# Включать только за надёжным reverse-proxy (nginx/traefik), иначе клиент
# подставит любой IP заголовком.
TRUST_PROXY=false

# ---------- Backend: auth/security ----------------------------------------
# HMAC-секрет для JWT. ОБЯЗАТЕЛЕН в production (NODE_ENV=production).
# В dev генерируется случайный при каждом старте (все токены инвалидируются
# на рестарт — это фича для дева, не для прода).
# Генерация: openssl rand -hex 32
JWT_SECRET=

# Прод-only: список доменов через запятую. В dev по умолчанию '*'.
# Открытый CORS в проде = CSRF-уязвимость, поэтому обязателен явный allowlist.
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Lockout per-username: после LOGIN_FAILURE_LIMIT провалов окно LOGIN_FAILURE_WINDOW_MS
# логин блокируется на LOGIN_LOCKOUT_MS. Защита от bruteforce.
LOGIN_FAILURE_LIMIT=5
LOGIN_FAILURE_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000

# Lockout per-IP: защита от credential-stuffing с rotation usernames.
# Пороги выше per-username (NAT-friendly).
LOGIN_IP_FAILURE_THRESHOLD=30
LOGIN_IP_FAILURE_WINDOW_MS=600000
LOGIN_IP_LOCKOUT_MS=1800000

# Refresh-токены: TTL + idle timeout + max sessions per user + replay-history.
REFRESH_TTL_MS=2592000000
REFRESH_IDLE_MS=1209600000
SESSIONS_PER_USER_MAX=5
REPLAY_HISTORY_TTL_MS=604800000
REPLAY_HISTORY_MAX=5000

# Пароль: минимальная длина (8 — RFC NIST 800-63B).
PASSWORD_MIN_LEN=8

# ---------- Backend: limits / backpressure -------------------------------
# Concurrent inflight: per-user (auth), per-IP (anon+auth), global cap.
# Поверх лимита — 503 с Retry-After. Подкрутите под нагрузку.
PER_USER_INFLIGHT_LIMIT=20
PER_IP_INFLIGHT_LIMIT=50
MAX_INFLIGHT_GLOBAL=800
BACKPRESSURE_RETRY_AFTER_S=2

# Per-request hard-таймаут: «зависший handler» гарантированно отвалится.
REQUEST_TIMEOUT_MS=30000
BULK_TIMEOUT_MS=120000

# Поля JSON-body: максимальная длина каждого строкового поля (защита от
# `name='A'.repeat(10MB)`).
MAX_FIELD_LEN=65536

# Page-size hard-кап (для list-эндпоинтов, ?pageSize=...).
PAGE_SIZE_HARD_MAX=500

# ---------- Backend: storage / backup -------------------------------------
# WAL auto-checkpoint: по размеру -wal или по возрасту.
WAL_ALERT_MB=100
WAL_AUTO_CHECKPOINT_MB=50
WAL_MAX_AGE_MS=3600000

# Авто-бэкап в data/backups/ раз в AUTO_BACKUP_INTERVAL_MS (0 = выключено).
# По умолчанию — раз в сутки, хранение 30 дней.
AUTO_BACKUP_INTERVAL_MS=86400000
BACKUP_KEEP_DAYS=30

# Audit-лог: рото-кап по возрасту записей (0 = выкл).
AUDIT_KEEP_DAYS=90

# Интервал фоновой maintenance (WAL checkpoint, backup, session cleanup).
MAINTENANCE_INTERVAL_MS=300000

# ---------- Backend: misc ------------------------------------------------
# Read-only режим: все мутации возвращают 503. Удобно для миграций/maintenance.
READ_ONLY=false

# Дренаж inflight при SIGTERM/SIGINT (важно для bulk-импортов).
SHUTDOWN_DRAIN_MS=5000

# Искусственная задержка mock-dispatcher'а (только для load-тестов).
MOCK_DELAY_MS=0

# NODE_ENV=production включает: обязательность JWT_SECRET и ALLOWED_ORIGINS,
# отключение console-debug, helmet-defaults и т.п.
NODE_ENV=development
